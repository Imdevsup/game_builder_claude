# =============================================================================
# Environment variables, copy to .env and fill in. Never commit .env.
# Each key links to where you sign up or generate it.
# =============================================================================

# --- Claude Code MCP servers ---

# GitHub Personal Access Token (free)
# https://github.com/settings/tokens, fine-grained, repo + PR scope is enough
GITHUB_TOKEN=

# Supabase project access token (free tier covers prototype)
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Brave Search API key (free 2,000 queries/month)
# https://brave.com/search/api/
BRAVE_API_KEY=

# Altab MCP server key (codebase intelligence layer)
# https://altab.ai
ALTAB_API_KEY=

# --- Game runtime ---

# Supabase project URL and keys (different from access token above)
# Found in your project's API settings.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database URL for Drizzle (use the pooled connection for runtime)
# postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- LLM providers (free tiers, see docs/ecosystem.md) ---

# Google AI Studio (Gemini, free tier, primary)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (free tier, fastest inference, Llama models)
# https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter (free tier, ~30 free models, one key for many)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cerebras (free tier, 1M tokens/day, fast)
# https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# Mistral (free tier, 1B tokens/month, all models)
# https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# --- Hosting (free tiers) ---

# Vercel (web hosting, generous hobby tier)
VERCEL_TOKEN=

# Fly.io (server hosting, generous free tier)
# Set with: fly auth token
FLY_API_TOKEN=

# --- Observability (free tiers) ---

# Sentry (free tier, 5K errors/month)
# https://sentry.io/
SENTRY_DSN=

# PostHog (free tier, 1M events/month, analytics + feature flags)
# https://posthog.com/
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# --- Optional ---

# OpenAI (no free tier in 2026 but useful for fallbacks if you have credits)
OPENAI_API_KEY=

# Anthropic (paid, only if you want a Claude option in the abstraction layer)
ANTHROPIC_API_KEY=
